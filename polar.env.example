# Copy these values into .env.local after creating products in Polar.
# Use POLAR_SERVER=sandbox while testing with Polar sandbox.

POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=<set-in-local-env>
POLAR_WEBHOOK_SECRET=<set-in-local-env>

# Monthly Pro subscription product.
POLAR_PRODUCT_ID_PRO=00000000-0000-0000-0000-000000000000

# Monthly individual tool subscription products.
POLAR_PRODUCT_ID_AIM_TOOLS=00000000-0000-0000-0000-000000000000
POLAR_PRODUCT_ID_NEXT_META=00000000-0000-0000-0000-000000000000
POLAR_PRODUCT_ID_PRO_MOVEMENT=00000000-0000-0000-0000-000000000000
POLAR_PRODUCT_ID_HOW_TO_BE_A_PRO=00000000-0000-0000-0000-000000000000
POLAR_PRODUCT_ID_PRO_SPAWN=00000000-0000-0000-0000-000000000000
POLAR_PRODUCT_ID_PRO_OPTI=00000000-0000-0000-0000-000000000000

# Configure this endpoint in Polar webhooks:
# https://your-domain.com/api/polar-webhook

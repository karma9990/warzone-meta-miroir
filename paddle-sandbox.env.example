# Copy these values into .env.local only when you want to run Paddle sandbox.
# Keep your live keys somewhere safe before replacing them locally.

NEXT_PUBLIC_PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_your_paddle_client_token
PADDLE_API_KEY=pdl_sandbox_your_api_key
PADDLE_WEBHOOK_SECRET=pdl_ntfset_your_sandbox_webhook_secret

# Pro subscription price. Use the sandbox price id from Paddle.
PADDLE_PRICE_ID_PRO=pri_your_sandbox_pro_price
NEXT_PUBLIC_PADDLE_PRICE_ID_PRO=pri_your_sandbox_pro_price

# Optional one-time tool prices. Fill only if you want to test individual tool purchases.
PADDLE_PRICE_ID_AIM_TOOLS=pri_your_sandbox_aim_tools_price
NEXT_PUBLIC_PADDLE_PRICE_ID_AIM_TOOLS=pri_your_sandbox_aim_tools_price
PADDLE_PRICE_ID_NEXT_META=pri_your_sandbox_next_meta_price
NEXT_PUBLIC_PADDLE_PRICE_ID_NEXT_META=pri_your_sandbox_next_meta_price
PADDLE_PRICE_ID_PRO_MOVEMENT=pri_your_sandbox_pro_movement_price
NEXT_PUBLIC_PADDLE_PRICE_ID_PRO_MOVEMENT=pri_your_sandbox_pro_movement_price
PADDLE_PRICE_ID_HOW_TO_BE_A_PRO=pri_your_sandbox_how_to_be_a_pro_price
NEXT_PUBLIC_PADDLE_PRICE_ID_HOW_TO_BE_A_PRO=pri_your_sandbox_how_to_be_a_pro_price
PADDLE_PRICE_ID_PRO_SPAWN=pri_your_sandbox_pro_spawn_price
NEXT_PUBLIC_PADDLE_PRICE_ID_PRO_SPAWN=pri_your_sandbox_pro_spawn_price
PADDLE_PRICE_ID_PRO_OPTI=pri_your_sandbox_pro_opti_price
NEXT_PUBLIC_PADDLE_PRICE_ID_PRO_OPTI=pri_your_sandbox_pro_opti_price

# Local webhook test helper. The script sends this dry-run header by default.
PADDLE_WEBHOOK_TEST_URL=http://localhost:3000/api/paddle-webhook
PADDLE_WEBHOOK_TEST_EMAIL=sandbox-webhook-test@example.com
PADDLE_WEBHOOK_TEST_DRY_RUN=1
